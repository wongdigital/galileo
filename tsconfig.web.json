{
  "compilerOptions": {
    "composite": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "paths": { "@renderer/*": ["./src/renderer/src/*"], "@shared/*": ["./src/shared/*"] }
  },
  // data/facet-map.json is a committed static table the renderer imports directly;
  // the LLM index is not listed, so a typecheck never walks the large file.
  "include": ["src/renderer/**/*", "src/shared/**/*", "src/preload/index.ts", "data/facet-map.json"]
}
